/* Custom Styles */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes shimmer {
    0% { background-position: -1000px 0; }
    100% { background-position: 1000px 0; }
}

.result-card {
    animation: fadeInUp 0.6s ease-out;
}

.skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 1000px 100%;
    animation: shimmer 2s infinite;
}

.toast {
    animation: slideInRight 0.3s ease-out;
}

@keyframes slideInRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* Dark Mode */
body.dark {
    background: linear-gradient(135deg, #1e1e2f 0%, #2d1b4e 100%);
}

/* Risk Badges */
.risk-safe { background: linear-gradient(135deg, #10b981, #059669); }
.risk-suspicious { background: linear-gradient(135deg, #f59e0b, #d97706); }
.risk-spam { background: linear-gradient(135deg, #ef4444, #dc2626); }
.risk-high-risk { background: linear-gradient(135deg, #7c3aed, #6d28d9); }

/* Scrollbar */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: rgba(0,0,0,0.1);
}

::-webkit-scrollbar-thumb {
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 10px;
}